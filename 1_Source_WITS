name: Source — WITS (tariffs, NTMs, trade restrictiveness) - PARQUET OPTIMIZED
description: >
  Independent Kubeflow/Elyra source component for WITS data.
  Runs in two modes:
    1. Production  — downloads wits_combined.csv from MinIO/B2 → parquet
    2. Synthetic   — generates synthetic WITS annual data       → parquet (use_synthetic=true)
  Outputs Snappy-compressed Parquet for fast downstream pipeline consumption.

inputs:
  - name: countries
    type: String
    description: 'Comma-separated ISO3 country codes. Example: "DEU,IND,NLD,NGA,USA"'

  - name: year_start
    type: Integer
    description: 'Start year (inclusive) for data range'

  - name: year_end
    type: Integer
    description: 'End year (inclusive) for data range'

  - name: use_synthetic
    type: String
    description: 'Set to "true" to generate synthetic data instead of downloading from MinIO'
    default: 'false'

  - name: minio_endpoint
    type: String
    description: 'MinIO / Backblaze B2 endpoint URL'
    default: 'https://s3.us-west-004.backblazeb2.com'

  - name: minio_access_key
    type: String
    description: 'MinIO / B2 access key'
    default: '005775aede18e2e0000000023'

  - name: minio_secret_key
    type: String
    description: 'MinIO / B2 secret key'
    default: 'K005GD3X7YxPdbUEtP9mfYwatqf/ugg'

  - name: bucket
    type: String
    description: 'Bucket name containing the WITS data'
    default: 'holacracydata'

  - name: prefix
    type: String
    description: 'Object prefix / folder path inside the bucket'
    default: 'connector_output'

outputs:
  - name: data
    type: Data
    description: 'WITS feature data (PARQUET format — Snappy compressed, pyarrow engine)'

  - name: metadata
    type: Data
    description: 'Load metadata JSON (source info, row count, columns, file size)'

implementation:
  container:
    image: nikhilv215/nesy-factory:v23
    command:
      - python3
      - -u
      - -c
      - |
        import os
        import sys
        import json
        import argparse
        import logging
        import time
        import tempfile
        import numpy as np
        import pandas as pd

        logging.basicConfig(
            level=logging.INFO,
            format="%(asctime)s [%(levelname)s] %(message)s"
        )
        log = logging.getLogger("source_wits")

        MINIO_FILENAME = "wits_combined.csv"


        def ensure_dir(path):
            directory = os.path.dirname(path)
            if directory:
                os.makedirs(directory, exist_ok=True)


        def make_s3_client(endpoint, access_key, secret_key):
            import boto3
            from botocore.config import Config as BotoConfig
            return boto3.client(
                "s3",
                endpoint_url=endpoint,
                aws_access_key_id=access_key,
                aws_secret_access_key=secret_key,
                config=BotoConfig(
                    signature_version="s3v4",
                    retries={"max_attempts": 5, "mode": "adaptive"},
                ),
            )


        def save_parquet(df, path):
            ensure_dir(path)
            for col in df.columns:
                if df[col].dtype == object:
                    sample = df[col].dropna().head(10)
                    if sample.apply(lambda x: isinstance(x, (list, dict))).any():
                        df[col] = df[col].apply(
                            lambda x: json.dumps(x) if isinstance(x, (list, dict)) else x
                        )
            df.to_parquet(path, index=False, engine="pyarrow", compression="snappy")
            size_mb = os.path.getsize(path) / 1e6
            log.info(f"Saved parquet -> {path}  ({len(df)} rows x {len(df.columns)} cols, {size_mb:.2f} MB)")
            return size_mb


        def download_from_minio(endpoint, access_key, secret_key, bucket, prefix, output_path, meta_path):
            object_key = f"{prefix}/{MINIO_FILENAME}".lstrip("/")
            log.info("=" * 60)
            log.info("DOWNLOADING FROM MINIO")
            log.info("=" * 60)
            log.info(f"Endpoint : {endpoint}")
            log.info(f"Bucket   : {bucket}")
            log.info(f"Object   : {object_key}")

            s3 = make_s3_client(endpoint, access_key, secret_key)

            with tempfile.NamedTemporaryFile(suffix=".csv", delete=False) as tmp:
                tmp_path = tmp.name
            try:
                t0 = time.time()
                s3.download_file(bucket, object_key, tmp_path)
                raw_size = os.path.getsize(tmp_path)
                log.info(f"Downloaded {raw_size/1e6:.1f} MB in {time.time()-t0:.1f}s")
                df = pd.read_csv(tmp_path, low_memory=False)
            finally:
                if os.path.exists(tmp_path):
                    os.remove(tmp_path)
                    log.info("Cleaned up temporary file")

            size_mb = save_parquet(df, output_path)

            meta = {
                "source": "wits",
                "mode": "production",
                "filename": MINIO_FILENAME,
                "object_key": object_key,
                "endpoint": endpoint,
                "bucket": bucket,
                "raw_size_mb": round(raw_size / 1e6, 2),
                "output_size_mb": round(size_mb, 2),
                "rows": len(df),
                "columns": list(df.columns),
                "output_path": output_path,
                "output_format": {
                    "format": "parquet",
                    "engine": "pyarrow",
                    "compression": "snappy"
                }
            }

            ensure_dir(meta_path)
            with open(meta_path, "w") as f:
                json.dump(meta, f, indent=2)
            log.info(f"Metadata saved -> {meta_path}")
            return meta


        def generate_synthetic(countries, year_start, year_end):
            log.info("=" * 60)
            log.info("GENERATING SYNTHETIC WITS DATA")
            log.info("=" * 60)
            log.info(f"Countries : {countries}")
            log.info(f"Years     : {year_start} - {year_end}")

            rows = []
            for iso in countries:
                for yr in range(year_start, year_end + 1):
                    rows.append({
                        "reporter":              iso,
                        "year":                  yr,
                        "tariff_applied_rate":   float(np.random.uniform(0, 20)),
                        "trade_openness":        float(np.random.uniform(20, 120)),
                        "tariff_dispersion":     float(np.random.uniform(1, 15)),
                        "trade_restrictiveness": float(np.random.uniform(0, 50)),
                        "ntm_count":             float(np.random.uniform(10, 300)),
                        "ntm_coverage_ratio":    float(np.random.uniform(10, 80)),
                        "ntm_frequency_index":   float(np.random.uniform(0.1, 0.9)),
                    })

            df = pd.DataFrame(rows)
            log.info(f"Generated {len(df)} rows x {len(df.columns)} columns")
            return df


        def main():
            parser = argparse.ArgumentParser(description="Source component: WITS")
            parser.add_argument("--countries",        required=True)
            parser.add_argument("--year_start",       type=int, required=True)
            parser.add_argument("--year_end",         type=int, required=True)
            parser.add_argument("--use_synthetic",    default="false")
            parser.add_argument("--minio_endpoint",   default="https://s3.us-west-004.backblazeb2.com")
            parser.add_argument("--minio_access_key", default="005775aede18e2e0000000023")
            parser.add_argument("--minio_secret_key", default="K005GD3X7YxPdbUEtP9mfYwatqf/ugg")
            parser.add_argument("--bucket",           default="holacracydata")
            parser.add_argument("--prefix",           default="connector_output")
            parser.add_argument("--output_data",      required=True)
            parser.add_argument("--output_metadata",  required=True)
            args = parser.parse_args()

            log.info("=" * 60)
            log.info("  SOURCE: WITS (tariffs, NTMs, trade restrictiveness)")
            log.info("=" * 60)
            log.info(f"Countries    : {args.countries}")
            log.info(f"Year range   : {args.year_start} - {args.year_end}")
            log.info(f"Synthetic    : {args.use_synthetic}")

            ensure_dir(args.output_data)
            ensure_dir(args.output_metadata)

            use_synthetic = args.use_synthetic.strip().lower() in ("true", "1", "yes")

            try:
                if use_synthetic:
                    countries = [c.strip() for c in args.countries.split(",") if c.strip()]
                    df = generate_synthetic(countries, args.year_start, args.year_end)
                    size_mb = save_parquet(df, args.output_data)

                    meta = {
                        "source": "wits",
                        "mode": "synthetic",
                        "countries": countries,
                        "year_start": args.year_start,
                        "year_end": args.year_end,
                        "rows": len(df),
                        "columns": list(df.columns),
                        "output_path": args.output_data,
                        "output_size_mb": round(size_mb, 2),
                        "output_format": {
                            "format": "parquet",
                            "engine": "pyarrow",
                            "compression": "snappy"
                        }
                    }
                    ensure_dir(args.output_metadata)
                    with open(args.output_metadata, "w") as f:
                        json.dump(meta, f, indent=2)
                    log.info(f"Metadata saved -> {args.output_metadata}")

                else:
                    meta = download_from_minio(
                        args.minio_endpoint,
                        args.minio_access_key,
                        args.minio_secret_key,
                        args.bucket,
                        args.prefix,
                        args.output_data,
                        args.output_metadata,
                    )

                log.info("")
                log.info("=" * 60)
                log.info("SOURCE: WITS COMPLETED SUCCESSFULLY")
                log.info("=" * 60)
                log.info(f"Mode    : {'synthetic' if use_synthetic else 'production'}")
                log.info(f"Rows    : {meta['rows']}")
                log.info(f"Columns : {len(meta['columns'])}")
                log.info(f"Format  : PARQUET (snappy)")
                log.info(f"Output  : {args.output_data}")
                log.info("=" * 60)

            except Exception as e:
                log.error(f"ERROR: {str(e)}")
                import traceback
                traceback.print_exc()
                sys.exit(1)


        if __name__ == "__main__":
            main()
      - --countries
      - {inputValue: countries}
      - --year_start
      - {inputValue: year_start}
      - --year_end
      - {inputValue: year_end}
      - --use_synthetic
      - {inputValue: use_synthetic}
      - --minio_endpoint
      - {inputValue: minio_endpoint}
      - --minio_access_key
      - {inputValue: minio_access_key}
      - --minio_secret_key
      - {inputValue: minio_secret_key}
      - --bucket
      - {inputValue: bucket}
      - --prefix
      - {inputValue: prefix}
      - --output_data
      - {outputPath: data}
      - --output_metadata
      - {outputPath: metadata}
